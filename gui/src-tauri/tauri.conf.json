{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lathe",
  "version": "0.1.0",
  "identifier": "com.vacantsystems.lathe",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lathe",
        "width": 860,
        "height": 560,
        "minWidth": 680,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
